APP_ENV=local
APP_BASE_URL=http://localhost:8000
MINI_APP_URL=http://localhost:8000/miniapp/
APP_SECRET=replace_with_long_random_secret
API_BIND=0.0.0.0
API_PORT=8000

BOT_TOKEN=replace_with_botfather_token
ADMIN_TELEGRAM_IDS=123456789

TELEGRAM_API_ID=123456
TELEGRAM_API_HASH=replace_with_my_telegram_org_hash
TELEGRAM_SESSIONS_DIR=/data/sessions

DATABASE_URL=postgresql+psycopg://autopost:autopost@postgres:5432/autopost
SCHEDULER_TICK_SECONDS=15
WORKER_TICK_SECONDS=5
DEFAULT_MIN_SEND_INTERVAL_SECONDS=30
